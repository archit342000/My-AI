FROM python:3.12-slim

# Create user
RUN groupadd -r appgroup && useradd -r -g appgroup -m -d /app appuser

WORKDIR /app

# Install isolated dependencies (no Flask, ChromaDB, etc.)
COPY tavily_mcp/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy code
COPY tavily_mcp /app/tavily_mcp

# Set ownership
RUN chown -R appuser:appgroup /app

USER appuser

EXPOSE 8000

CMD ["python3", "-m", "tavily_mcp.server"]
