FROM python:3.12-slim

# Create user
RUN groupadd -r appgroup && useradd -r -g appgroup -m -d /app appuser

WORKDIR /app

# Install isolated dependencies (no Flask, ChromaDB, etc.)
COPY mcp_server/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy code
COPY mcp_server /app/mcp_server

# Set ownership
RUN chown -R appuser:appgroup /app

USER appuser

EXPOSE 8000

CMD ["python3", "-m", "mcp_server.server"]
